# ── Pappers API ──────────────────────────────────────────
PAPPERS_API_KEY=your_pappers_api_key_here

# ── Anthropic / Claude ───────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Vercel KV (Redis) ────────────────────────────────────
# Généré automatiquement par : vercel kv create plu-cache
# Puis : vercel env pull .env.local
KV_REST_API_URL=https://xxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=your_kv_token_here

# ── App ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001

# ── Sentry (frontend) ────────────────────────────────────
# DSN disponible sur sentry.io → Settings → Projects → Client Keys
VITE_SENTRY_DSN=
CRON_SECRET=
MAX_SEARCHES_PER_USER=4